{
    "manifest_version": 3,
    "name": "CodeStreak",
    "version": "1.0.0",
    "description": "Track your DSA practice across platforms",
    "permissions": [
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://leetcode.com/*",
        "https://codeforces.com/*",
        "http://localhost:5173/*",
        "http://localhost:5000/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://leetcode.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/codestreak-favicon.png",
            "48": "icons/codestreak-favicon.png",
            "128": "icons/codestreak-favicon.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "externally_connectable": {
        "matches": [
            "http://localhost:5173/*"
        ]
    }
}